        {
            "name": "Debug Driver Unit Test - Select",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:selectDriverUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        },
        {
            "name": "Debug Driver Unit Test - Last Selected",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:lastDriverUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true,
        },
        {
            "name": "Debug Service Unit Test - Select",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:selectSvcUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        },
        {
            "name": "Debug Service Unit Test - Last Selected",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:lastSvcUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        },
        {
            "name": "Debug Init Unit Test - Select",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:selectInitUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        },
        {
            "name": "Debug Init Unit Test - Last Selected",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:lastInitUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        }
    ],
    "inputs": [
        {
            "id": "programName",
            "description": "Program to Run",
            "default": "",
            "type": "promptString"
        },
        {
            "id": "selectDriverUnitTest",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "description": "Pick a Driver unit test to run",
                "key": "savedDriverUnitTest",
                "options": [
                    [
                        "Sensor Fifo Driver",
                        "kng.driver.sensor_fifo.test.exe"
                    ],
                    [
                        "ICC MHU Driver",
                        "kng.driver.icc_mhu_trans.test.exe"
                    ],
                    [
                        "SCMI Driver",
                        "kng.driver.scmi_drv.test.exe"
                    ]
                ],
            },
        },
        {
            "id": "lastDriverUnitTest",
            "type": "command",
            "command": "extension.commandvariable.remember",
            "args": {
                "key": "savedDriverUnitTest"
            }
        },
        {
            "id": "selectSvcUnitTest",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "description": "Pick a service unit test to run",
                "key": "savedSvcUnitTest",
                "options": [
                    [
                        "Data Collection Service",
                        "kng.service.dcs.test.exe"
                    ],
                    [
                        "Sensor Fifo Service",
                        "service.sensor_fifo.test.exe"
                    ],
                    [
                        "Event Trace Relay Service",
                        "service.event_trace.relay.test.exe"
                    ],
                    [
                        "Telemetry Service - Data Proc Cmpnt",
                        "kng.service.telemetry.cmpnt.data_process.test"
                    ],
                    [
                        "Telemetry Service - Exec Cmpnt",
                        "kng.service.telemetry.cmpnt.exec.test"
                    ],
                    [
                        "Telemetry Service - In Band Cmpnt",
                        "kng.service.telemetry.cmpnt.in_band_tlm.test"
                    ],
                ],
            },
        },
        {
            "id": "lastSvcUnitTest",
            "type": "command",
            "command": "extension.commandvariable.remember",
            "args": {
                "key": "savedSvcUnitTest"
            }
        },
        {
            "id": "selectInitUnitTest",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "description": "Pick a init unit test to run",
                "key": "savedInitUnitTest",
                "options": [
                    [
                        "ICC Init",
                        "icc_init.test.exe"
                    ],
                ],
            },
        },
        {
            "id": "lastInitUnitTest",
            "type": "command",
            "command": "extension.commandvariable.remember",
            "args": {
                "key": "savedInitUnitTest"
            }
        }

    ]
}
