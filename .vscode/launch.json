{
    "configurations": [
        {
            "name": "SCP App SVP",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm",
            "miDebuggerPath":  "${workspaceFolder}/.externs/azpkg/gdb.arm.eabi.aarch-win64.8.3.201903/arm-none-eabi-gdb.exe",
            "miDebuggerArgs":  "--symbols=${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/scp_fw.elf",
            // port determined from svp launch configuration
            "miDebuggerServerAddress": "localhost:12348",
            "program": "${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/scp_fw.elf",
            "args": [],
            "MIMode": "gdb",
            "cwd": "${workspaceFolder}",
            "customLaunchSetupCommands": [
                {
                    // port determined from svp launch configuration
                    "text": "target remote localhost:12348",
                    "description": "Attach to remote target",
                    "ignoreFailures": false
                }
            ]
        },
