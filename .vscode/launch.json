{
    "configurations": [
        {
            "name": "(Windows) Launch",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${input:programName}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal"
        },
        {
            "name": "MCP SVP - DIE 0",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm",
            "miDebuggerPath":  "${workspaceFolder}/.externs/azpkg/gdb.arm.eabi.aarch-win64.8.3.201903/arm-none-eabi-gdb.exe",
            "miDebuggerArgs":  "--symbols=${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/mcp/mcp_fw.elf",
            // port determined from svp launch configuration
            "miDebuggerServerAddress": "localhost:12366",
            "program": "${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/mcp/mcp_fw.elf",
            "args": [],
            "MIMode": "gdb",
            "cwd": "${workspaceFolder}",
            "customLaunchSetupCommands": [
                {
                    // port determined from svp launch configuration
                    "text": "target remote localhost:12366",
                    "description": "Attach to remote target",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "SCP SVP - DIE 0",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm",
            "miDebuggerPath":  "${workspaceFolder}/.externs/azpkg/gdb.arm.eabi.aarch-win64.8.3.201903/arm-none-eabi-gdb.exe",
            "miDebuggerArgs":  "--symbols=${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/scp/scp_fw.elf",
            // port determined from svp launch configuration
            "miDebuggerServerAddress": "localhost:12367",
            "program": "${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/scp/scp_fw.elf",
            "args": [],
            "MIMode": "gdb",
            "cwd": "${workspaceFolder}",
            "customLaunchSetupCommands": [
                {
                    // port determined from svp launch configuration
                    "text": "target remote localhost:12367",
                    "description": "Attach to remote target",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "Debug Lib Unit Test - Select",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:selectLibUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        },
        {
            "name": "Debug Lib Unit Test - Last Selected",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:lastLibUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        },
        {
            "name": "Debug Service Unit Test - Select",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:selectSvcUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        },
        {
            "name": "Debug Service Unit Test - Last Selected",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin/${input:lastSvcUnitTest}",
            "symbolSearchPath": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}/.build/Debug/i386-pc-windows-msvc/bin",
            "console": true
        }
    ],
    "inputs": [
        {
            "id": "programName",
            "description": "Program to Run",
            "default": "",
            "type": "promptString"
        },
        {
            "id": "selectLibUnitTest",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "description": "Pick a Lib unit test to run",
                "key": "savedLibUnitTest",
                "options": [
                    [
                        "Sensor Fifo Driver",
                        "kng.driver.sensor_fifo.test.exe"
                    ],
                ],
            },
        },
        {
            "id": "lastLibUnitTest",
            "type": "command",
            "command": "extension.commandvariable.remember",
            "args": {
                "key": "savedLibUnitTest"
            }
        },
        {
            "id": "selectSvcUnitTest",
            "type": "command",
            "command": "extension.commandvariable.pickStringRemember",
            "args": {
                "description": "Pick a service unit test to run",
                "key": "savedSvcUnitTest",
                "options": [
                    [
                        "Sensor Fifo Service",
                        "service.sensor_fifo.test.exe"
                    ],
                ],
            },
        },
        {
            "id": "lastSvcUnitTest",
            "type": "command",
            "command": "extension.commandvariable.remember",
            "args": {
                "key": "savedSvcUnitTest"
            }
        }

    ]
}