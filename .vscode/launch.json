{
    "configurations": [
        {
            "name": "(Windows) Launch",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${input:programName}",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "externalTerminal"
        },
        {
            "name": "MCP SVP - DIE 0",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm",
            "miDebuggerPath":  "${workspaceFolder}/.externs/azpkg/gdb.arm.eabi.aarch-win64.8.3.201903/arm-none-eabi-gdb.exe",
            "miDebuggerArgs":  "--symbols=${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/mcp/mcp_fw.elf",
            // port determined from svp launch configuration
            "miDebuggerServerAddress": "localhost:12352",
            "program": "${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/mcp/mcp_fw.elf",
            "args": [],
            "MIMode": "gdb",
            "cwd": "${workspaceFolder}",
            "customLaunchSetupCommands": [
                {
                    // port determined from svp launch configuration
                    "text": "target remote localhost:12352",
                    "description": "Attach to remote target",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "SCP SVP - DIE 0",
            "type": "cppdbg",
            "request": "launch",
            "targetArchitecture": "arm",
            "miDebuggerPath":  "${workspaceFolder}/.externs/azpkg/gdb.arm.eabi.aarch-win64.8.3.201903/arm-none-eabi-gdb.exe",
            "miDebuggerArgs":  "--symbols=${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/scp/scp_fw.elf",
            // port determined from svp launch configuration
            "miDebuggerServerAddress": "localhost:12353",
            "program": "${workspaceFolder}/.build/Debug/arm-eabi-aarch/bin/scp/scp_fw.elf",
            "args": [],
            "MIMode": "gdb",
            "cwd": "${workspaceFolder}",
            "customLaunchSetupCommands": [
                {
                    // port determined from svp launch configuration
                    "text": "target remote localhost:12353",
                    "description": "Attach to remote target",
                    "ignoreFailures": false
                }
            ]
        },
    ],
    "inputs": [
        {
            "id": "programName",
            "description": "Program to Run",
            "default": "",
            "type": "promptString"
        }
    ]
}