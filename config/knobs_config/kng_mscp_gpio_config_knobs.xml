    <Knob name="gpio_knobs" type="gpio_cfg_t" help="GPIO config knobs"/>
    <Knob name="uart_afm_cfg_die0" type="uart_afm_cfg_t" help="UART AFM config knobs for Die 0"/>
    <Knob name="uart_afm_cfg_die1" type="uart_afm_cfg_t" help="UART AFM config knobs for Die 1"/>
  </Knobs>

</ConfigSchema>