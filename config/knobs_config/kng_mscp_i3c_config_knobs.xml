<ConfigSchema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:noNamespaceSchemaLocation="configschema.xsd">

  <!-- Enum values are declared separately from the knobs.
       The same Enum can be used as the 'enumtype' of any number of EnumKnobs -->
  <Enums>
  </Enums>

  <Structs>
  </Structs>

  <!-- namespace indicates the GUID namespace the values are stored in -->
  <Knobs namespace="{FE3ED49F-B173-41ED-9076-356661D46A42}">
    <!-- I3C -->
    <Knob name="i3c_speed" type="i3c_speed_t" default="I3C_SPEED_SDR4_2MHz" help="Desired I3C Speed for I3C0 and I3C1" />
    <Knob name="reg_scl_ext_termn_lcnt_timing" type="uint32_t" default="0xF" help="Set value for REG_SCL_EXT_TERMN_LCNT_TIMING" />
    <Knob name="reg_sda_hold_switch_dly_timing" type="uint32_t" default="0x50000" help="Set value for REG_SDA_HOLD_SWITCH_DLY_TIMING" />
    <Knob name="timing_override" type="bool" default="false" help="Override the Timing Control Registers" />
    <Knob name="reg_scl_i3c_od_timing" type="uint32_t" default="0xA0010" help="Set value for REG_SCL_I3C_OD_TIMING" />
    <Knob name="reg_scl_i3c_pp_timing" type="uint32_t" default="0xA000A" help="Set value for REG_SCL_I3C_PP_TIMING" />
    <Knob name="reg_scl_i2c_fm_timing" type="uint32_t" default="0x100010" help="Set value for REG_SCL_I2C_FM_TIMING" />
    <Knob name="reg_scl_i2c_fmp_timing" type="uint32_t" default="0x100010" help="Set value for REG_SCL_I2C_FMP_TIMING" />
    <Knob name="reg_scl_ext_lcnt_timing" type="uint32_t" default="0x20202020" help="Set value for REG_SCL_EXT_LCNT_TIMING" />
    <Knob name="vdd" type="uint16_t" default="0x0" help="Set PMIC value for VDD to the DIMM (Rails SWA, SWB), PMIC Internal default if knob is 0, Range 1000 to 1200" />
    <Knob name="vddq" type="uint16_t" default="0x0" help="Set PMIC value for VDDQ to the DIMM (Rails SWC), PMIC Internal default if knob is 0, Range 1000 to 1200" />
    <Knob name="disable_dimm_param_check" type="bool" default="0x0" help="Disable checking the DIMM params. Default: 0x0(DIMM Check is Enabled)" />
  </Knobs>

</ConfigSchema>
