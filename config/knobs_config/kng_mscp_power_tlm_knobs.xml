<ConfigSchema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
 xsi:noNamespaceSchemaLocation="configschema.xsd">

  <!-- Enum values are declared separately from the knobs.
       The same Enum can be used as the 'enumtype' of any number of EnumKnobs -->
  <Enums>
    <Enum name="power_tlm_inst_sample_period_t" help="">
      <Value name="PWR_TLM_INST_SAMPLE_PERIOD_5_MS" prettyname="5 mS" value="1" help="create inst record's every 5 mS" />
      <Value name="PWR_TLM_INST_SAMPLE_PERIOD_10_MS" prettyname="10 mS" value="2" help="create inst record's every 10 mS" />
      <Value name="PWR_TLM_INST_SAMPLE_PERIOD_20_MS" prettyname="20 mS" value="4" help="create inst record's every 20 mS" />
      <Value name="PWR_TLM_INST_SAMPLE_PERIOD_40_MS" prettyname="40 mS" value="8" help="create inst record's every 40 mS" />
      <Value name="PWR_TLM_INST_SAMPLE_PERIOD_100_MS" prettyname="100 mS" value="20" help="create inst record's every 100 mS" />
    </Enum>
    <Enum name="power_tlm_prod_package_period_t" help="">
      <Value name="PWR_TLM_PROD_PKG_PERIOD_30_SEC" prettyname="30 seconds" value="1" help="create production package every 30 sec" />
      <Value name="PWR_TLM_PROD_PKG_PERIOD_1_MIN" prettyname="1 minute" value="2" help="create production package every minute" />
      <Value name="PWR_TLM_PROD_PKG_PERIOD_2_MIN" prettyname="2 minute" value="3" help="create production package every 2 minutes" />
    </Enum>
    <Enum name="power_tlm_24hr_package_period_t" help="">
      <Value name="PWR_TLM_24HR_PKG_PERIOD_24_HR" prettyname="24 hours" value="1" help="create production package every 24 hours" />
      <Value name="PWR_TLM_24HR_PKG_PERIOD_60_MIN" prettyname="60 minutes" value="2" help="create production package every 60 minutes" />
      <Value name="PWR_TLM_24HR_PKG_PERIOD_30_MIN" prettyname="30 minutes" value="3" help="create production package every 30 minutess" />
    </Enum>
  </Enums>

  <Structs>
    <Struct name="power_tlm_knobs_t" help="">
      <Member name="inst_sample_period" type="power_tlm_inst_sample_period_t" default="PWR_TLM_INST_SAMPLE_PERIOD_10_MS" help="Inst Record Sampling Period" />
      <Member name="prod_pkg_period" type="power_tlm_prod_package_period_t" default="PWR_TLM_PROD_PKG_PERIOD_2_MIN" help="Production Package Period" />
      <Member name="inst_samples_per_pkg" type="uint16_t" default="10" help="Package generated every n inst_sample_period" />
      <Member name="_24hr_sample_period" type="power_tlm_24hr_package_period_t" default="PWR_TLM_24HR_PKG_PERIOD_24_HR" help="24 Hr Package Sampling Period" />
    </Struct>

    <Struct name="power_tlm_mpam_mcp_knobs_t" help="">
      <Member name="fixed_pwr_mW" type="uint32_t" default="0" help="Memory Controller Power plus PHY Power" />
      <Member name="mem_pwr_primary_enable" type="bool" default="false" help="Enable MPAM vM memory collection" />
    </Struct>

    <Struct name="power_tlm_mpam_scp_knobs_t" help="">
      <Member name="T2_thresh" type="uint8_t" default="67" help="T2 Utilization Threshold" />
      <Member name="T1_thresh" type="uint8_t" default="66" help="T1 Utilization Threshold" />
      <Member name="T0_thresh" type="uint8_t" default="65" help="T0 Utilization Threshold" />
      <Member name="enc_wr_rel_pwr" type="uint8_t" default="1" help="Encrypted Write Relative Power" />
      <Member name="unenc_wr_rel_pwr" type="uint8_t" default="1" help="Unencrypted Write Relative Power" />
      <Member name="enc_rd_rel_pwr" type="uint8_t" default="1" help="Encrypted Read Relative Power" />
      <Member name="unenc_rd_rel_pwr" type="uint8_t" default="1" help="Unencrypted Read Relative Power" />
    </Struct>
  </Structs>

  <!-- namespace indicates the GUID namespace the values are stored in -->
  <Knobs namespace="{FE3ED49F-B173-41ED-9076-356661D46A42}">
    <Knob name="pwr_tlm_knobs" type="power_tlm_knobs_t" help="Power Telemetry knobs"/>
    <Knob name="pwr_tlm_mpam_mcp_knobs" type="power_tlm_mpam_mcp_knobs_t" help="Power Telemetry MCP Mpam VM knobs"/>
    <Knob name="pwr_tlm_mpam_scp_knobs" type="power_tlm_mpam_scp_knobs_t" help="Power Telemetry SCP Mpam VM knobs"/>
  </Knobs>

</ConfigSchema>